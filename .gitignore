# Visual Studio user specific files
.vs/

# Visual Studio workload requirements
/.vsconfig

# Rider user specific files
.idea/

# VS Code user specific files
.vscode/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa
!Doc/convert.exe

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/*/Binaries/*

# Ignore Mod source files, but track the archived files
Mods/*
!Mods/*.zip

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/*/*.keystore

# Allow Build/Engine/** for our engine build scripts
!Build/Engine/**

# Allow Build/BatchFiles/** for some of our additional tools
!Build/BatchFiles/**

# Allow Build/Scripts for AutomationTool scripts
!Build/Scripts/**
Build/Scripts/obj/**

# Allow Build/ActionRPG/** for our ARPG release scripts
!Build/ActionRPG/**

# Include res folder in Build
!Build/*/res/
!Build/*/res/**

# Don't ignore icon files in Build
!Build/**/*.ico

# Ignore Automation csproj props file
/Build/Scripts/ActionRPG.Automation.csproj.props

# Built data for maps
*_BuiltData.uasset

# Ignore all build data for platforms
/Platforms/*/Build/FileOpenOrder/*
/Platforms/*/Build/Resources/*

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*
Plugins/Developers/*

# Cache files for the editor to use
DerivedDataCache/*

# Doc output file
out/docs

Plugins/Modio/Source/Modio/GeneratedHeader/*
Plugins/Modio/Source/Modio/GeneratedSource/*
Plugins/Modio/Source/MSDFSupport/GeneratedSource/*
Plugins/Modio/Source/ThirdParty/GeneratedNativeSDK/*
Plugins/Modio/Source/uring/Private/GeneratedSource/*
Plugins/Modio/Source/mbedtls/Private/GeneratedSource/*
Plugins/Modio/Source/ThirdParty/GeneratedMSDFgen/*
Plugins/Modio/Source/ThirdParty/GeneratedMbedtlsSource/*
Plugins/Modio/Source/ThirdParty/GeneratedUringSource/*
Plugins/Modio/Source/ModioEditor/Resources/Downloaded/*

# Cache directory for ccls
.ccls-cache

# Ignore any base releases that have been made
Releases/*

# Unreal user specific developer files
/Plugins/Developer/*
/Content/Developers/*

# Sentry crash reporting files
.sentry-native/*

# Allow all files in Sentry folder, except binaries and intermediate files
!Plugins/Sentry/**
Plugins/Sentry/Binaries/*
Plugins/Sentry/Intermediate/*

# Created by ushell to make blueprint projects work end to end.
/Source/ActionRPGClient.Target.cs

/ArchivedBuilds/*
